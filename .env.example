# ============================================
# Backend (FastAPI)
# ============================================

# Server host and port
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# CORS origins (comma-separated, for development)
CORS_ORIGINS=http://localhost:5173

# Simulation defaults
DEFAULT_G=1.0
DEFAULT_SOFTENING=0.001
DEFAULT_TIMESTEP=0.01

# ============================================
# Frontend (Vite + React)
# ============================================

# Backend API URL (used by frontend to connect)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ============================================
# Future / Optional
# ============================================

# Uncomment when adding deployment
# PRODUCTION_URL=
# GITHUB_PAGES_URL=
